root = true

[*.{py,ipynb,json,md,txt,toml,yaml,yml,xml,html,css,js,ts,tsx}]
charset = utf-8
insert_final_newline = true
end_of_line = lf

[*.csv]
charset = utf-8-bom
insert_final_newline = true
end_of_line = crlf

[*.{ps1,cmd,bat}]
charset = utf-8-bom
insert_final_newline = true
end_of_line = crlf
